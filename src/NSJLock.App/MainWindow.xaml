<Window x:Class="NSJLock.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:config="clr-namespace:NSJLock.Config;assembly=NSJLock.Config"
        Title="NSJ Lock"
        Width="520"
        MinWidth="460"
        MinHeight="620"
        ResizeMode="CanMinimize"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="NSJ Lock"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontSize="30"
                           FontWeight="SemiBold" />
                <TextBlock Text="系统声音保护"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="14"
                           Margin="0,4,0,0" />
            </StackPanel>

            <Grid Grid.Row="1"
                  Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ComboBox Height="42"
                          Margin="0,0,10,0"
                          SelectedValuePath="Tag"
                          SelectedValue="{Binding ThemeMode, Mode=TwoWay}">
                    <ComboBoxItem Content="跟随系统"
                                  Tag="{x:Static config:AppThemeMode.System}" />
                    <ComboBoxItem Content="浅色"
                                  Tag="{x:Static config:AppThemeMode.Light}" />
                    <ComboBoxItem Content="深色"
                                  Tag="{x:Static config:AppThemeMode.Dark}" />
                </ComboBox>

                <Border Grid.Column="1"
                        BorderThickness="1"
                        CornerRadius="8"
                        Height="42"
                        Padding="12,0"
                        Margin="0,0,10,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsProtectionEnabled}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Ellipse Width="7"
                                 Height="7"
                                 Margin="0,0,7,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{DynamicResource MutedTextBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsProtectionEnabled}" Value="True">
                                            <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding ProtectionStateText}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="86" />
                    </StackPanel>
                </Border>

                <Button Grid.Column="2"
                        Content="{Binding ProtectionButtonText}"
                        Command="{Binding ToggleProtectionCommand}"
                        Style="{StaticResource ProtectionButtonStyle}" />
            </Grid>
        </Grid>

        <Border Grid.Row="1"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource HairlineBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="18">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="锁定目标"
                               Foreground="{DynamicResource MutedTextBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,14,0" />
                    <ComboBox Grid.Column="1"
                              Height="38"
                              ItemsSource="{Binding OutputDeviceOptions}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="DeviceId"
                              SelectedValue="{Binding LockedDeviceId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <Grid Grid.Row="1"
                          Grid.ColumnSpan="2"
                          Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="82" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="目标"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontSize="11"
                                   Margin="0,0,12,5" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding LockedTargetValueText}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,0,0,5" />

                        <TextBlock Grid.Row="1"
                                   Text="系统输出"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontSize="11"
                                   Margin="0,0,12,5" />
                        <TextBlock Grid.Row="1"
                                   Grid.Column="1"
                                   Text="{Binding SystemDefaultOutputValueText}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,0,0,5" />

                        <TextBlock Grid.Row="2"
                                   Text="Zoom"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontSize="11"
                                   Margin="0,0,12,0" />
                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   Text="{Binding ZoomOutputValueText}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap" />

                        <TextBlock Grid.Row="3"
                                   Grid.ColumnSpan="2"
                                   Text="{Binding OutputWarningText}"
                                   Foreground="{DynamicResource WarningAccentBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0" />
                    </Grid>
                </Grid>

                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="210" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Width="184"
                          Height="184"
                          HorizontalAlignment="Left">
                        <Ellipse Fill="{DynamicResource MeterInnerBrush}"
                                 Stroke="{DynamicResource MeterBorderBrush}"
                                 StrokeThickness="1" />
                        <Ellipse Margin="16"
                                 Stroke="{DynamicResource ProgressTrackBrush}"
                                 StrokeThickness="14" />
                        <Ellipse Margin="16"
                                 StrokeThickness="14"
                                 StrokeStartLineCap="Round"
                                 StrokeEndLineCap="Round"
                                 StrokeDashArray="{Binding CurrentVolumePercent, Converter={StaticResource PercentToStrokeDashArrayConverter}}"
                                 StrokeDashOffset="25"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.Stroke>
                                <LinearGradientBrush StartPoint="0.15,0.85"
                                                     EndPoint="0.8,0.05">
                                    <GradientStop Color="#20B5E8"
                                                  Offset="0" />
                                    <GradientStop Color="#25DCA0"
                                                  Offset="0.52" />
                                    <GradientStop Color="#61D8A2"
                                                  Offset="1" />
                                </LinearGradientBrush>
                            </Ellipse.Stroke>
                            <Ellipse.RenderTransform>
                                <RotateTransform Angle="150" />
                            </Ellipse.RenderTransform>
                        </Ellipse>

                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Text="当前声音"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       FontSize="12"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding CurrentVolumePercent, StringFormat={}{0}%}"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       FontSize="38"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0" />
                            <TextBlock Text="系统主音量"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                        <TextBlock Text="声音锁"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   FontSize="22"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SoundLockDescriptionText}"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,18" />

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="锁定音量"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontSize="12" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding SoundLockLimitText}"
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontSize="24"
                                       FontWeight="SemiBold" />
                        </Grid>
                        <ProgressBar Minimum="0"
                                     Maximum="100"
                                     Value="{Binding MaxVolumePercent, Mode=OneWay}"
                                     Foreground="{DynamicResource AccentBrush}" />

                        <Grid Margin="0,16,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="当前声音"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontSize="12" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding CurrentVolumePercent, StringFormat={}{0}%}"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                        </Grid>
                        <ProgressBar Minimum="0"
                                     Maximum="100"
                                     Value="{Binding CurrentVolumePercent, Mode=OneWay}"
                                     Foreground="{DynamicResource CurrentLevelBrush}" />
                    </StackPanel>
                </Grid>

                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource HairlineBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="16,12">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="调节锁定值"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           FontSize="16"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="拖动滑杆设置系统主音量会被拉回的位置。"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           FontSize="12"
                                           Margin="0,4,0,0" />
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Background="{DynamicResource AccentSoftBrush}"
                                    CornerRadius="8"
                                    Padding="12,7"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding SoundLockLimitText}"
                                           Foreground="{DynamicResource AccentBrush}"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                            </Border>
                        </Grid>

                        <Slider Minimum="10"
                                Maximum="100"
                                TickFrequency="5"
                                IsSnapToTickEnabled="True"
                                Value="{Binding MaxVolumePercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                VerticalAlignment="Center" />

                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="更安静"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       FontSize="11" />
                            <TextBlock Grid.Column="2"
                                       Text="更响亮"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       FontSize="11" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>
